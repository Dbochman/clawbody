# ClawBody Configuration
# Give your OpenClaw AI agent a physical robot body!

# ==============================================================================
# REQUIRED: OpenAI API Key
# ==============================================================================
# Get your key at: https://platform.openai.com/api-keys
# Requires Realtime API access
OPENAI_API_KEY=sk-your-openai-key

# ==============================================================================
# REQUIRED: OpenClaw Gateway
# ==============================================================================
# The URL where your OpenClaw gateway is running
# If running on the same machine as the robot, use the host machine's IP
OPENCLAW_GATEWAY_URL=http://192.168.1.100:18789

# Your OpenClaw gateway authentication token
# Find this in ~/.openclaw/openclaw.json under gateway.token
OPENCLAW_TOKEN=your-gateway-token

# Agent ID to use (default: main)
OPENCLAW_AGENT_ID=main

# Session key for conversation context - IMPORTANT!
# Use "main" (default) to share context with WhatsApp and other DM channels
# This allows the robot to be aware of all your conversations
OPENCLAW_SESSION_KEY=main

# ==============================================================================
# OPTIONAL: Voice Settings
# ==============================================================================
# OpenAI Realtime voice
OPENAI_VOICE=cedar

# Fast native audio-to-audio model for ordinary Reachy conversation
OPENAI_MODEL=gpt-realtime-2.1-mini

# direct: Realtime answers ordinary turns and delegates skills to OpenClaw
# openclaw: compatibility fallback where OpenClaw processes every voice turn
REACHY_VOICE_MODE=direct

# Small pre-roll buffer keeps native streamed audio smooth at speaker startup
OPENAI_AUDIO_JITTER_MS=220

# Allow user speech to stop current playback and begin a new turn
REACHY_BARGE_IN=false

# Keep microphone audio local until the bundled openWakeWord model hears
# "Hey Claude". The initial timeout is only the time allowed to start speaking;
# once speech starts, the utterance is not limited to ten seconds.
REACHY_WAKE_WORD_ENABLED=false
REACHY_WAKE_WORD_THRESHOLD=0.5
REACHY_WAKE_WORD_INITIAL_TIMEOUT_SECONDS=10
REACHY_WAKE_WORD_FOLLOWUP_TIMEOUT_SECONDS=20

# Poll the trusted capsule/SOUL RPC; this does not run an OpenClaw agent turn
CONTINUITY_REFRESH_SECONDS=2
CONTINUITY_SUMMARY_MODEL=gpt-5.4-mini

# Stop a delegated OpenClaw request from holding a voice turn indefinitely
OPENCLAW_DELEGATION_TIMEOUT_SECONDS=75

# ==============================================================================
# OPTIONAL: Features
# ==============================================================================
# Enable/disable features (true/false)
ENABLE_CAMERA=true
ENABLE_OPENCLAW_TOOLS=true
